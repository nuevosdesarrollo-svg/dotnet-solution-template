## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
[Aa]rtifacts/
out/

# .NET test results
[Tt]est[Rr]esult*/
*.trx
*.coverage
*.coveragexml
coverage/

# NuGet
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets

# Rider / VS Code / VS
.idea/
.vscode/
.vs/

# Logs
*.log

# OS generated files
.DS_Store
Thumbs.db

# DotNet tool files
.dotnet/

# MAUI / Xamarin
*.keystore
*.jks
google-services.json
GoogleService-Info.plist
